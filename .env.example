# Kopieer naar .env.local en vul daar echte waarden in — NOOIT echte secrets in dit bestand plakken (staat in git).
# Zie README en docs/OPENAI-DEPLOY.md voor productie-env.

# === Supabase (verplicht) ===
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
#
# Google Sign-In: Supabase Dashboard → Authentication → Providers → Google (OAuth Client ID + Secret).
# Redirect URLs moeten o.a. bevatten: https://jouwdomein.nl/auth/callback en http://localhost:3000/auth/callback (dev).

# === Publieke app-URL (verplicht in productie) ===
# Exact de URL waar klanten de site openen, ZONDER trailing slash.
# Moet gelijk zijn aan Supabase → Authentication → Site URL (bijv. https://zylmero.com).
NEXT_PUBLIC_SITE_URL=https://zylmero.com
SITE_URL=https://zylmero.com
# AUTH_PUBLIC_ORIGIN=
# NEXT_PUBLIC_APP_URL=

# Custom SMTP (bijv. Resend) voor betrouwbare auth-mail.

NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# === OpenAI (server-only — nooit NEXT_PUBLIC_) ===
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_GROWTH=
STRIPE_PRICE_PRO=

CRON_SECRET=
RESEND_API_KEY=
RESEND_FROM_EMAIL=Zylmero <onboarding@resend.dev>
FOUNDER_USER_IDS=
# Jouw Supabase user UUID(s): altijd dashboard + server-acties (leads/AI/inbox), ook zonder abonnement.
PLATFORM_HOST_USER_IDS=
NEXT_PUBLIC_ZYLMERO_DEMO=
WHATSAPP_WEBHOOK_SECRET=
INBOUND_EMAIL_WEBHOOK_SECRET=

# === Meta (Facebook / Instagram OAuth) — optioneel ===
# App Dashboard → Facebook Login → OAuth redirect URI moet exact overeenkomen met:
#   {NEXT_PUBLIC_SITE_URL of SITE_URL}/api/oauth/meta/callback
META_APP_ID=
META_APP_SECRET=
# 32+ bytes random hex/base64 voor AES-256-GCM seal van page access tokens (server-only).
SOCIAL_TOKEN_KEY=

# === Kanaal integraties (optioneel, voor connecties) ===
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=

EMAIL_IMAP_HOST=
EMAIL_IMAP_PORT=993
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587
EMAIL_USERNAME=
EMAIL_PASSWORD=
EMAIL_SMTP_SECURE=false

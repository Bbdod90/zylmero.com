# === Supabase (verplicht) ===
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# === Publieke app-URL (verplicht in productie) ===
# Exact de URL waar klanten de site openen, ZONDER trailing slash.
# Moet gelijk zijn aan Supabase → Authentication → Site URL (bijv. https://zylmero.com).
# Op je telefoon werkt http://localhost niet — gebruik je LAN-IP, ngrok, of de live URL.
NEXT_PUBLIC_SITE_URL=https://zylmero.com
# Zelfde als hierboven, maar server-only: wordt bij Railway/Vercel op runtime gelezen (Next bakt
# NEXT_PUBLIC_* soms in bij `next build`). Voorkomt dat oude builds localhost in bevestigingsmail zetten.
# Nooit https://localhost:8080 — dat is alleen de interne containerpoort op Railway, niet je openbare domein.
SITE_URL=https://zylmero.com
# Optioneel: harde basis voor auth-redirects (Location-header na /auth/callback). Zet dit als je nog
# steeds naar localhost:8080 wordt gestuurd op Railway: AUTH_PUBLIC_ORIGIN=https://zylmero.com
# AUTH_PUBLIC_ORIGIN=
# Optioneel: alias voor dezelfde waarde
# NEXT_PUBLIC_APP_URL=

# In Supabase → Redirect URLs: https://zylmero.com/** (zelfde host als Site URL)
# Custom SMTP (bijv. Resend) voor betrouwbare auth-mail.

NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_GROWTH=
STRIPE_PRICE_PRO=

CRON_SECRET=
RESEND_API_KEY=
RESEND_FROM_EMAIL=Zylmero <onboarding@resend.dev>
FOUNDER_USER_IDS=
# Alleen "true" voor gedwongen demo-UI; in productie leeg laten
NEXT_PUBLIC_ZYLMERO_DEMO=
WHATSAPP_WEBHOOK_SECRET=

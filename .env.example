# Kopieer naar .env.local en vul daar echte waarden in — NOOIT echte secrets in dit bestand plakken (staat in git).
# Zie README en docs/OPENAI-DEPLOY.md voor productie-env.

# === Supabase (verplicht) ===
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# === Publieke app-URL (verplicht in productie) ===
# Exact de URL waar klanten de site openen, ZONDER trailing slash.
# Moet gelijk zijn aan Supabase → Authentication → Site URL (bijv. https://zylmero.com).
NEXT_PUBLIC_SITE_URL=https://zylmero.com
SITE_URL=https://zylmero.com
# AUTH_PUBLIC_ORIGIN=
# NEXT_PUBLIC_APP_URL=

# Custom SMTP (bijv. Resend) voor betrouwbare auth-mail.

NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# === OpenAI (server-only — nooit NEXT_PUBLIC_) ===
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_GROWTH=
STRIPE_PRICE_PRO=

CRON_SECRET=
RESEND_API_KEY=
RESEND_FROM_EMAIL=Zylmero <onboarding@resend.dev>
FOUNDER_USER_IDS=
NEXT_PUBLIC_ZYLMERO_DEMO=
WHATSAPP_WEBHOOK_SECRET=
INBOUND_EMAIL_WEBHOOK_SECRET=
